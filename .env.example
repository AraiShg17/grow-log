# Google Cloud (home-items-app)
GCP_PROJECT_ID=home-items-app
FIRESTORE_DATABASE_ID=grow-log-db
GCS_BUCKET_NAME=home-items-app-grow-log-photos

# Firebase Admin (local: optional if using Application Default Credentials)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OpenAI（ローカル用。sk-your-key のままでは登録できません）
# 本番: Secret Manager projects/714015956955/secrets/OPEN_AI_API_KEY
OPENAI_API_KEY=
# または OPEN_AI_API_KEY=（どちらか一方）
OPENAI_MODEL=gpt-5.4-mini
